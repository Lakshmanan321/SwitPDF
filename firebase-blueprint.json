{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and SaaS tier details",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "tier": { "type": "string", "enum": ["free", "pro"] },
        "subscriptionExpires": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["email", "displayName", "createdAt", "tier", "isAdmin"]
    },
    "UsageLog": {
      "title": "Usage Log",
      "description": "Tracks tool executions for rate limiting",
      "type": "object",
      "properties": {
        "toolId": { "type": "string" },
        "toolName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["toolId", "toolName", "timestamp", "fileName", "status"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback or support tickets submitted by users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "rating": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "resolved"] }
      },
      "required": ["userId", "userEmail", "message", "timestamp", "status"]
    },
    "Transaction": {
      "title": "Billing Transaction",
      "description": "Simulated payment transactions for subscriptions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "planName": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["userId", "userEmail", "amount", "currency", "planName", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Primary user profile, subscription tier, and admin flag"
    },
    "/users/{userId}/usageLogs/{logId}": {
      "schema": "UsageLog",
      "description": "Subcollection to log each execution of a PDF/image tool for that user"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User-submitted feedback or suggestions"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Audit log of simulated subscription purchases/payments"
    }
  }
}
